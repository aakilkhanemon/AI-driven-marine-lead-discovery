import pandas as pd
import networkx as nx
import matplotlib.pyplot as plt
import matplotlib.patches as patches
import requests
import time

# 1. Target Lists for Compounds 1-6 (UniProt IDs)
compounds_targets = {
    "Compound_1": ["P56817", "P22303", "Q9BY41", "Q92769", "P56524", "P06276", "P09917", "Q9UNI1", "Q92731", "O75460", "O14788", "P03372", "P48147", "P34972", "P21554"],
    "Compound_2": ["P04278", "Q92731", "P03372", "P22736", "P00915", "Q01959", "P18031", "P08575", "P30305", "P04150", "P31645", "P35968", "P00918", "Q16790", "O43570"],
    "Compound_3": ["P05177", "Q01959", "P23975", "Q02127", "Q92847", "Q9Y5N1", "P35354", "Q16665", "P35968", "P07333", "P17948", "P00918", "P00915", "Q06187", "P35228"],
    "Compound_4": ["Q86WV6", "O15393", "O00411", "Q8TEK3", "P13569", "P37023", "P42336", "P08473", "P42892", "P12821", "O75907", "Q06187", "P51449", "O14829", "P04818"],
    "Compound_5": ["P30542", "P0DMS8", "P29274", "Q99808", "P55263", "Q99720", "P23975", "O43318", "Q01959", "P27487", "O14744", "Q9BQA1", "P23526", "P11142", "P11021", "P00813"],
    "Compound_6": ["P14061", "P30542", "P29274", "P0DMS8", "P21589", "Q86U44", "P00533", "P04626", "O00408", "P36888", "Q16539", "P54646", "P08183", "O14744"]
}

# Standard cytoHubba Heat Palette (Rank 1 -> Rank 10)
def get_hub_color(rank):
    colors = ['#FF0000', '#FF4500', '#FF8C00', '#FFA500', '#FFD700',
              '#FFFF00', '#FFFF33', '#FFFF66', '#FFFF99', '#FFFFCC']
    return colors[min(rank, len(colors)-1)]

# 2. Loop Through Each Compound
for comp_name, uniprot_ids in compounds_targets.items():
    print(f"Generating cytoHubba Network for {comp_name}...")

    # Resolve network mapping via STRING API v12
    string_api_url = "https://version12.string-db.org/api/json/network"
    params = {
        "identifiers": "\r".join(uniprot_ids),
        "species": 9606,
        "required_score": 700,
        "caller_identity": f"mpox_{comp_name.lower()}_cyto"
    }

    try:
        response = requests.post(string_api_url, data=params)
        response.raise_for_status()
        data = response.json()
        if not data:
            print(f"No interactions found for {comp_name}. Skipping.")
            continue
        df = pd.DataFrame(data)
    except Exception as e:
        print(f"API Error on {comp_name}: {e}")
        continue

    # 3. Build Network and Calculate Degree Topology
    G = nx.Graph()
    for _, row in df.iterrows():
        G.add_edge(row['preferredName_A'], row['preferredName_B'])

    degree_dict = dict(G.degree())

    # Sort and capture the Top 10 Hub Nodes
    top_nodes = sorted(degree_dict.items(), key=lambda x: x[1], reverse=True)[:10]
    hub_names = [node[0] for node in top_nodes]
    subG = G.subgraph(hub_names)

    # 4. Canvas Configurations
    fig, ax = plt.subplots(figsize=(15, 9), dpi=300)
    plt.subplots_adjust(left=0.3)

    # Calculate spring layout layout constraints
    pos = nx.spring_layout(subG, k=1.8, seed=42)

    # Draw Background Edges
    nx.draw_networkx_edges(subG, pos, ax=ax, width=2, edge_color='#2C3E50', alpha=0.7)

    # 5. Draw cytoHubba-Style Node Boxes
    for node, (x, y) in pos.items():
        # Pinpoint the node's ranking index
        rank = next(idx for idx, (name, val) in enumerate(top_nodes) if name == node)
        color = get_hub_color(rank)

        # Build characteristic rounded node box
        rect = patches.FancyBboxPatch((x-0.14, y-0.07), 0.28, 0.14,
                                      boxstyle="round,pad=0.02",
                                      linewidth=2, edgecolor='#2C3E50', facecolor=color)
        ax.add_patch(rect)
        ax.text(x, y, node, ha='center', va='center', fontsize=12, fontweight='bold', fontfamily='sans-serif')

    # 6. Build the Matplotlib Ranking Table
    table_data = [[i+1, node] for i, (node, deg) in enumerate(top_nodes)]
    the_table = plt.table(cellText=table_data, colLabels=['Rank', 'Node'],
                          loc='left', cellLoc='center', colWidths=[0.07, 0.15])

    the_table.auto_set_font_size(False)
    the_table.set_fontsize(11)
    the_table.scale(1.2, 2.3)

    # Inject exact hex code gradients into table cell matrices
    for i in range(len(table_data)):
        the_table[(i+1, 0)].set_facecolor(get_hub_color(i))
        the_table[(i+1, 1)].set_facecolor(get_hub_color(i))

    ax.axis('off')
    clean_title = comp_name.replace("_", " ")
    plt.title(f"{clean_title}: cytoHubba Hub Selection (Top 10 by Degree)", fontsize=16, fontweight='bold', pad=30)

    # Save high-res png output
    output_name = f"{comp_name}_cytoHubba_Top10.png"
    plt.savefig(output_name, bbox_inches='tight', dpi=600)
    plt.close()
    print(f"Successfully generated and saved {output_name}")

    time.sleep(1)


import pandas as pd
import requests
import networkx as nx
from google.colab import files
import time

def generate_compound_metrics_table(uniprot_list, compound_name):
    print(f"🔄 Characterizing topology for {compound_name}...")

    # 1. Map UniProt IDs to Official Gene Names to avoid raw accessions in table
    string_id_url = "https://string-db.org/api/json/get_string_ids"
    id_params = {
        "identifiers": "\r".join(uniprot_list),
        "species": 9606,
        "caller_identity": f"mpox_{compound_name.lower()}_map"
    }

    try:
        id_resp = requests.post(string_id_url, data=id_params)
        id_data = id_resp.json()

        # Create mapping dictionary {string_internal_id: official_gene_symbol}
        # and a set of preferred names to handle isolated singletons accurately
        id_map = {item['stringId']: item['preferredName'] for item in id_data}
        all_mapped_genes = set(item['preferredName'] for item in id_data)

        if not id_map:
            print(f"⚠️ Could not map identifiers for {compound_name}. Proceeding with raw data.")
            all_mapped_genes = set(uniprot_list)
    except Exception as e:
        print(f"⚠️ ID Mapping failed ({e}). Node names might fall back to raw inputs.")
        id_map = {}
        all_mapped_genes = set(uniprot_list)

    # 2. Fetch Interactions from STRING API (v12.0)
    string_api_url = "https://string-db.org/api/json/network"
    params = {
        "identifiers": "\r".join(uniprot_list),
        "species": 9606,
        "required_score": 700, # High-Confidence Threshold
        "caller_identity": f"mpox_{compound_name.lower()}_metrics"
    }

    try:
        response = requests.post(string_api_url, data=params)
        network_data = response.json()
        df = pd.DataFrame(network_data)

        # Initialize Graph
        G = nx.Graph()

        if not df.empty:
            # Build edges using preferred names directly from the interaction payload
            for _, row in df.iterrows():
                G.add_edge(row['preferredName_A'], row['preferredName_B'])

        # Explicitly add all mapped input targets to capture zero-degree isolates/singletons
        G.add_nodes_from(all_mapped_genes)

        if len(G.nodes) == 0:
            print(f"⚠️ Empty network generated for {compound_name}.")
            return None

        # 3. Calculate NetworkX Topological Centralities
        degree_dict = dict(G.degree())
        betweenness_dict = nx.betweenness_centrality(G, normalized=True)

        # 4. Build and Format the Metrics Table (Matching the user screenshot)
        metrics_df = pd.DataFrame({
            'Node Name': list(degree_dict.keys()),
            'Degree (k)': [degree_dict[node] for node in degree_dict.keys()],
            'Betweenness Centrality (Cb)': [round(betweenness_dict[node], 6) for node in degree_dict.keys()]
        })

        # Sort by Degree (Primary) and Betweenness (Secondary) descending
        metrics_df = metrics_df.sort_values(by=['Degree (k)', 'Betweenness Centrality (Cb)'], ascending=False).reset_index(drop=True)

        # 5. Export and Auto-Download CSV for ESI
        filename = f"Table_S2_{compound_name}_Topological_Metrics.csv"
        metrics_df.to_csv(filename, index=True, index_label="Index")
        files.download(filename)

        print(f"✅ {compound_name} complete. Table saved as '{filename}'.")

        # Render clean view in Colab output cell
        return metrics_df

    except Exception as e:
        print(f"❌ Error in {compound_name} metrics compilation: {e}")
        return None

