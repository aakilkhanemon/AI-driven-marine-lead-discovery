}

# Color palette for distinct visualization across figures
colors = ["#1a5276", "#27ae60", "#9b59b6", "#e67e22", "#e74c3c", "#34495e"]

# 2. Iterate through each compound to query STRING and generate network plots
for i, (comp_name, targets) in enumerate(compounds_targets.items()):
    print(f"Processing STRING network for {comp_name} ({len(targets)} targets)...")

    # Fetching STRING Data (High Confidence Threshold 0.700)
    string_url = "https://string-db.org/api/json/network"
    params = {
        "identifiers": "\r".join(targets),
        "species": 9606,            # Human taxonomy ID
        "required_score": 700,      # High confidence threshold
        "caller_identity": f"mpox_{comp_name.lower()}"
    }

    try:
        response = requests.post(string_url, data=params)
        response.raise_for_status()
        res = response.json()
    except Exception as e:
        print(f"Error fetching data for {comp_name}: {e}")
        continue

    # 3. Graph Construction
    G = nx.Graph()

    # Maps queried identifiers to mapped names returned by STRING to prevent mixed label schemes
    mapped_nodes = set()
    for edge in res:
        node_a = edge['preferredName_A']
        node_b = edge['preferredName_B']
        G.add_edge(node_a, node_b, weight=edge['score'])
        mapped_nodes.update([node_a, node_b])

    # Handle singletons/isolates that do not have high-confidence edges
    # STRING API maps input IDs to native names. To ensure labels are coherent,
    # isolates are added dynamically if they aren't explicitly caught in the edge mapping.
    G.add_nodes_from(mapped_nodes)

    if len(G.nodes) == 0:
        print(f"No interactions found at confidence score 0.700 for {comp_name}. Skipping visual plot.")
        continue

    # 4. Topological Scaling
    degree = dict(G.degree())
    node_sizes = [v * 500 + 800 for v in degree.values()] # Scaled for clarity

    # 5. Visual Rendering (Super High Res)
    plt.figure(figsize=(10, 10), dpi=300)
    pos = nx.kamada_kawai_layout(G)

    # Draw Edges
    nx.draw_networkx_edges(G, pos, width=1.5, edge_color='#D3D3D3', alpha=0.6)

    # Draw Nodes
    nx.draw_networkx_nodes(G, pos, node_size=node_sizes, node_color=colors[i],
                           edgecolors='white', linewidths=1.5)

    # Draw Labels
    nx.draw_networkx_labels(G, pos, font_size=10, font_family='sans-serif',
                            font_weight='bold', font_color='black')

    plt.title(f"Target Interaction Network: {comp_name.replace('_', ' ')} (n={len(G.nodes)})", fontsize=14, pad=15)
    plt.axis('off')

    # 6. Saving the Publication-Ready File
    file_name = f"{comp_name}_Network_HighRes.png"
    plt.savefig(file_name, format='png', bbox_inches='tight', dpi=600)
    plt.close() # Close plot to clear memory in Colab loops
    print(f"Saved {file_name}")

    # Brief pause to respect API rate limits
    time.sleep(1)

