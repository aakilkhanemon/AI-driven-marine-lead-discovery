import rdkit
from rdkit import Chem
from rdkit.Chem import AllChem
import psi4

# Initialize Psi4 settings
psi4.set_memory('12 GB')
psi4.set_num_threads(2)

# Your dataset mapped directly from the image (Lead 1 omitted to prevent RAM crashes)
smiles_dict = {
    "Compound_2": "Cc1cc(Br)c(O)c(Br)c1C1=C[C@H]2C[C@H](CO)O[C@@H]2[C@@H](C)C1",
    "Compound_3": "Cc1noc(C)c1C(=O)Nc1ccc(F)cc1",
    "Compound_4": "C[C@H](N[P@](=O)(OC[C@@H]1O[C@](C#N)(c2ccc3c(N)ncnn23)[C@H](O)[C@H]1O)Oc1ccccc1)C(=O)O",
    "Compound_5": "CC#CNc1ncnc2c1ncn2[C@@H]1O[C@H](CO)[C@H](O)[C@@H]1O",
    "Compound_6": "Cc1cc(Br)c(O)c(Br)c1C1=C[C@H]2C[C@H](n3cnc4c(N)ncnc43)O[C@@H]2[C@@H](C)C1"
}

results = {}

for name, smiles in smiles_dict.items():
    print(f"\n==================== Processing {name} ====================")

    # 1. Generate 3D Conformation
    mol = Chem.MolFromSmiles(smiles)
    mol = Chem.AddHs(mol)
    AllChem.EmbedMolecule(mol, AllChem.ETKDGv3())
    AllChem.MMFFOptimizeMolecule(mol, maxIters=500)

    # 2. Convert to Psi4 format string
    conf = mol.GetConformer()
    xyz_string = "0 1\n"  # Neutral, singlet state
    for atom in mol.GetAtoms():
        pos = conf.GetAtomPosition(atom.GetIdx())
        xyz_string += f"{atom.GetSymbol()} {pos.x:10.4f} {pos.y:10.4f} {pos.z:10.4f}\n"

    # 3. Load into Psi4
    psi_mol = psi4.geometry(xyz_string)

    # 4. DFT Energy Calculation (using uniform 3-21G for thesis consistency)
    method = 'b3lyp/3-21g'
    print(f"[{name}] Running Single-Point DFT using {method}...")

    try:
        energy, wfn = psi4.energy(method, molecule=psi_mol, return_wfn=True)
        hartree_to_ev = 27.211386

        n_alpha = wfn.nalpha()
        homo_ev = wfn.epsilon_a().get(n_alpha - 1) * hartree_to_ev
        lumo_ev = wfn.epsilon_a().get(n_alpha) * hartree_to_ev
        gap_ev = lumo_ev - homo_ev

        results[name] = {
            "HOMO (eV)": round(homo_ev, 3),
            "LUMO (eV)": round(lumo_ev, 3),
            "Gap (eV)": round(gap_ev, 3),
            "Status": "Success"
        }
    except Exception as e:
        print(f"Error calculating {name}: {str(e)}")
        results[name] = {"HOMO (eV)": "N/A", "LUMO (eV)": "N/A", "Gap (eV)": "N/A", "Status": "Failed"}

    psi4.core.clean()

# Final Presentation
print("\n" + "="*50)
print("                  FINAL THESIS DATA TABLE        ")
print("="*50)
print(f"{'Compound':<12} | {'HOMO (eV)':<10} | {'LUMO (eV)':<10} | {'Gap (eV)':<10} | {'Status'}")
print("-" * 65)
for comp, data in results.items():
    print(f"{comp:<12} | {data['HOMO (eV)']:<10} | {data['LUMO (eV)']:<10} | {data['Gap (eV)']:<10} | {data['Status']}")


