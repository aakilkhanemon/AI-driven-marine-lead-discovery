from rdkit import Chem
from rdkit.Chem import AllChem
import pyscf
from pyscf import dft
import numpy as np

# Your dataset (Lead 1 omitted to prevent memory limitations)
smiles_dict = {
    "Compound_2": "Cc1cc(Br)c(O)c(Br)c1C1=C[C@H]2C[C@H](CO)O[C@@H]2[C@@H](C)C1",
    "Compound_3": "Cc1noc(C)c1C(=O)Nc1ccc(F)cc1",
    "Compound_4": "C[C@H](N[P@](=O)(OC[C@@H]1O[C@](C#N)(c2ccc3c(N)ncnn23)[C@H](O)[C@H]1O)Oc1ccccc1)C(=O)O",
    "Compound_5": "CC#CNc1ncnc2c1ncn2[C@@H]1O[C@H](CO)[C@H](O)[C@@H]1O",
    "Compound_6": "Cc1cc(Br)c(O)c(Br)c1C1=C[C@H]2C[C@H](n3cnc4c(N)ncnc43)O[C@@H]2[C@@H](C)C1"
}

results = {}

for name, smiles in smiles_dict.items():
    print(f"\n==================== Processing {name} ====================")
    try:
        # 1. 3D Conformation Generation via RDKit
        mol = Chem.MolFromSmiles(smiles)
        mol = Chem.AddHs(mol)
        AllChem.EmbedMolecule(mol, AllChem.ETKDGv3())
        AllChem.MMFFOptimizeMolecule(mol, maxIters=500)

        # 2. Build geometry string for PySCF
        conf = mol.GetConformer()
        pyscf_geom = ""
        for atom in mol.GetAtoms():
            pos = conf.GetAtomPosition(atom.GetIdx())
            pyscf_geom += f"{atom.GetSymbol()} {pos.x} {pos.y} {pos.z}; "

        # 3. Initialize PySCF Molecule Object
        pyscf_mol = pyscf.gto.Mole()
        pyscf_mol.atom = pyscf_geom[:-2] # Strip trailing semicolon
        pyscf_mol.basis = '3-21g'        # Thesis uniform basis set
        pyscf_mol.charge = 0
        pyscf_mol.spin = 0               # Singlet state
        pyscf_mol.build()

        # 4. Set up and run B3LYP DFT calculation
        print(f"[{name}] Running DFT calculation (B3LYP/3-21G)...")
        mf = dft.RKS(pyscf_mol)
        mf.xc = 'b3lyp'
        mf.kernel()                      # Run SCF energy convergence

        # 5. Extract Molecular Orbitals (Convert from Hartrees to eV)
        hartree_to_ev = 27.211386
        mo_energies = mf.mo_energy * hartree_to_ev

        # Find the HOMO and LUMO indexes based on electron occupation numbers
        # mo_occ tells us how many electrons are in each orbital (2 for closed shell)
        n_occupied = np.count_nonzero(mf.mo_occ > 0)

        homo_ev = mo_energies[n_occupied - 1]
        lumo_ev = mo_energies[n_occupied]
        gap_ev = lumo_ev - homo_ev

        results[name] = {
            "HOMO (eV)": round(homo_ev, 3),
            "LUMO (eV)": round(lumo_ev, 3),
            "Gap (eV)": round(gap_ev, 3),
            "Status": "Success"
        }
    except Exception as e:
        print(f"Error calculating {name}: {str(e)}")
        results[name] = {"HOMO (eV)": "N/A", "LUMO (eV)": "N/A", "Gap (eV)": "N/A", "Status": "Failed"}

# Final Presentation Data Table
print("\n" + "="*50)
print("                  FINAL THESIS DATA TABLE        ")
print("="*50)
print(f"{'Compound':<12} | {'HOMO (eV)':<10} | {'LUMO (eV)':<10} | {'Gap (eV)':<10} | {'Status'}")
