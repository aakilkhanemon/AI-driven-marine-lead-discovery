from rdkit import Chem
from rdkit.Chem import AllChem
import pyscf
from pyscf import dft, tools
import py3Dmol

# 1. Regenerate the quantum wave function for Compound 3
smiles = "Cc1noc(C)c1C(=O)Nc1ccc(F)cc1"
mol = Chem.MolFromSmiles(smiles)
mol = Chem.AddHs(mol)
AllChem.EmbedMolecule(mol, AllChem.ETKDGv3())
AllChem.MMFFOptimizeMolecule(mol, maxIters=500)

pyscf_geom = ""
for atom in mol.GetAtoms():
    pos = mol.GetConformer().GetAtomPosition(atom.GetIdx())
    pyscf_geom += f"{atom.GetSymbol()} {pos.x} {pos.y} {pos.z}; "

pyscf_mol = pyscf.gto.Mole()
pyscf_mol.atom = pyscf_geom[:-2]
pyscf_mol.basis = '3-21g'
pyscf_mol.build()

mf = dft.RKS(pyscf_mol)
mf.xc = 'b3lyp'
mf.kernel()

# 2. Identify HOMO and LUMO orbital indices
n_occupied = int(sum(mf.mo_occ > 0))
homo_idx = n_occupied - 1
lumo_idx = n_occupied

# 3. Export spatial density distributions to standard Gaussian .cube files
print("Generating spatial grid cube files...")
tools.cubegen.orbital(pyscf_mol, 'homo.cube', mf.mo_coeff[:, homo_idx])
tools.cubegen.orbital(pyscf_mol, 'lumo.cube', mf.mo_coeff[:, lumo_idx])

# 4. Render Interactive HTML Viewer using py3Dmol
def display_orbital(cube_file, title, iso_val=0.04):
    with open(cube_file, 'r') as f:
        cube_data = f.read()

    viewer = py3Dmol.view(width=500, height=400)
    viewer.addModel(cube_data, "cube")
    viewer.setStyle({'stick': {}})

    # Render the positive phase (Red) and negative phase (Blue) translucent lobes
    viewer.addIsosurface(cube_data, {'isoval': iso_val, 'color': 'red', 'opacity': 0.6})
    viewer.addIsosurface(cube_data, {'isoval': -iso_val, 'color': 'blue', 'opacity': 0.6})

    viewer.zoomTo()
    print(f"\n=== 3D Rendering: {title} ===")
    viewer.show()

# Display both orbitals sequentially
display_orbital('homo.cube', "HOMO (Highest Occupied Molecular Orbital)")
display_orbital('lumo.cube', "LUMO (Lowest Unoccupied Molecular Orbital)")
