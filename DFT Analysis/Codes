import pandas as pd

# 1. Input data exactly as generated by your PySCF execution
raw_data = {
    "Compound": ["Compound_2", "Compound_3", "Compound_4", "Compound_5", "Compound_6"],
    "HOMO (eV)": [-6.064, -6.048, -5.910, -6.068, -5.889],
    "LUMO (eV)": [-0.579, -0.962, -0.827, -1.138, -0.642]
}

# 2. Convert to DataFrame for easier mathematical transformations
df = pd.DataFrame(raw_data)

# 3. Calculate Global Reactivity Descriptors using Koopmans' Theorem equations
df["Gap (eV)"] = df["LUMO (eV)"] - df["HOMO (eV)"]
df["Electronegativity (chi, eV)"] = - (df["HOMO (eV)"] + df["LUMO (eV)"]) / 2
df["Chemical Potential (mu, eV)"] = - df["Electronegativity (chi, eV)"]
df["Global Hardness (eta, eV)"] = (df["LUMO (eV)"] - df["HOMO (eV)"]) / 2
df["Global Softness (S, 1/eV)"] = 1 / (2 * df["Global Hardness (eta, eV)"])
df["Electrophilicity Index (omega, eV)"] = (df["Chemical Potential (mu, eV)"]**2) / (2 * df["Global Hardness (eta, eV)"])

# Round all values uniformly to 3 decimal places for formal thesis publication
df_rounded = df.round(3)

# 4. Display the Final Table
print("="*105)
print("                           EXTENDED GLOBAL REACTIVITY DESCRIPTORS FOR THESIS")
print("="*105)
print(df_rounded.to_string(index=False))
